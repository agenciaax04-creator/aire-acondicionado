---
const slides = [
  {
    alt: 'Oferta: Minisplit LG 1 tonelada $5,999.00',
    src: '/promotions/promo-1.jpeg',
  },
  {
    alt: 'Oferta: Minisplit MIRAGE 1 tonelada $5,799.00',
    src: '/promotions/promo-2.jpeg',
  },
  {
    alt: 'Oferta: Minisplit 1 tonelada $4,999.00',
    src: '/promotions/promo-3.jpeg',
  },
  {
    alt: 'Oferta: Minisplit MIRAGE 1 tonelada $5,999.00',
    src: '/promotions/promo-4.jpeg',
  },
];

const whatsappNumber = '529931524978';
const whatsappUrlFor = (alt, src) => {
  const text = `Hola, estoy interesado en la oferta: ${alt}. ¿Me puedes dar más información? (Imagen: ${src})`;
  return `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;
};
---

<section id="promociones" class="border-t border-slate-100 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-brand-navy">Promociones y ofertas</h2>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">
        Paquetes y descuentos por tiempo limitado.
      </p>
    </div>

    <div class="relative mt-10" data-promos-carousel>
      <div class="no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-2" data-promos-track>
        {slides.map((s) => (
          <div class="w-[82%] shrink-0 snap-start sm:w-[48%] lg:w-[32%]">
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-soft ring-1 ring-black/5">
              <a
                href={whatsappUrlFor(s.alt, s.src)}
                target="_blank"
                rel="noreferrer"
                class="block focus:outline-none focus:ring-4 focus:ring-brand-gold/30"
                aria-label={`Consultar por WhatsApp: ${s.alt}`}
              >
                <div class="aspect-square w-full bg-white">
                  <img src={s.src} alt={s.alt} class="h-full w-full object-contain" loading="lazy" />
                </div>
                <div class="border-t border-slate-200 px-4 py-3">
                  <p class="text-sm font-semibold leading-snug text-brand-navy">{s.alt}</p>
                  <p class="mt-1 text-xs text-slate-600">Toca para solicitar información por WhatsApp</p>
                </div>
              </a>
            </div>
          </div>
        ))}
      </div>

      <button
        type="button"
        class="absolute left-0 top-1/2 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-brand-navy text-white shadow-soft ring-1 ring-black/10 hover:brightness-110 md:inline-flex"
        aria-label="Anterior"
        data-promos-prev
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      <button
        type="button"
        class="absolute right-0 top-1/2 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-brand-navy text-white shadow-soft ring-1 ring-black/10 hover:brightness-110 md:inline-flex"
        aria-label="Siguiente"
        data-promos-next
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      <script is:inline>
        (() => {
          const root = document.currentScript?.closest('[data-promos-carousel]');
          if (!root) return;

          const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
          const track = root.querySelector('[data-promos-track]');
          const prev = root.querySelector('[data-promos-prev]');
          const next = root.querySelector('[data-promos-next]');

          if (!track) return;

          const scrollByAmount = () => {
            const first = track.querySelector(':scope > div');
            if (!first) return track.clientWidth;
            const styles = window.getComputedStyle(track);
            const gap = Number.parseFloat(styles.columnGap || styles.gap || '0') || 0;
            return first.getBoundingClientRect().width + gap;
          };

          const go = (dir) => {
            const amt = scrollByAmount();
            track.scrollBy({ left: dir * amt, behavior: reduced ? 'auto' : 'smooth' });
          };

          prev?.addEventListener('click', () => go(-1));
          next?.addEventListener('click', () => go(1));

          if (!reduced) {
            let timer = null;

            const start = () => {
              if (timer) return;
              timer = window.setInterval(() => {
                const max = track.scrollWidth - track.clientWidth;
                const atEnd = track.scrollLeft >= max - 2;
                if (atEnd) {
                  track.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                  go(1);
                }
              }, 3500);
            };

            const stop = () => {
              if (!timer) return;
              window.clearInterval(timer);
              timer = null;
            };

            root.addEventListener('mouseenter', stop);
            root.addEventListener('mouseleave', start);
            root.addEventListener('focusin', stop);
            root.addEventListener('focusout', start);

            start();
          }
        })();
      </script>
    </div>
  </div>
</section>

<style is:global>
  .no-scrollbar::-webkit-scrollbar {
    width: 0;
    height: 0;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
