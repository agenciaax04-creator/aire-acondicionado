---
const whatsappNumber = '529931524978';
const whatsappText = encodeURIComponent('Hola, me gustaría cotizar un servicio de aire acondicionado residencial.');
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noreferrer"
  class="fixed bottom-6 right-6 z-50 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-soft ring-1 ring-black/10 hover:brightness-110 focus:outline-none focus:ring-4 focus:ring-[#25D366]/30"
  aria-label="Enviar por WhatsApp"
>
  <svg width="26" height="26" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path
      fill="currentColor"
      d="M27.6 4.4A15.5 15.5 0 0 0 16.1 0C7.3 0 .2 7.1.2 15.9c0 2.8.7 5.5 2.1 7.9L0 32l8.4-2.2a15.8 15.8 0 0 0 7.7 2c8.8 0 15.9-7.1 15.9-15.9 0-4.2-1.6-8.2-4.4-11.5ZM16.1 29.2c-2.4 0-4.8-.6-6.9-1.9l-.5-.3-5 1.3 1.3-4.9-.3-.5a13.3 13.3 0 0 1-2-7c0-7.3 5.9-13.2 13.2-13.2 3.5 0 6.8 1.4 9.3 3.9a13.1 13.1 0 0 1 3.9 9.3c0 7.3-5.9 13.2-13.2 13.2Zm7.2-9.9c-.4-.2-2.3-1.1-2.7-1.2-.4-.2-.7-.2-1 .2-.3.4-1.1 1.2-1.4 1.5-.3.3-.5.3-.9.1-.4-.2-1.7-.6-3.2-2-1.2-1.1-2-2.5-2.2-2.9-.2-.4 0-.6.2-.8.2-.2.4-.5.6-.7.2-.2.3-.4.4-.6.1-.2.1-.5 0-.7-.1-.2-1-2.4-1.4-3.3-.4-.9-.7-.8-1-.8h-.8c-.3 0-.7.1-1 .5-.3.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.8c.2.2 2.5 3.9 6.1 5.5.9.4 1.6.6 2.1.8.9.3 1.7.3 2.3.2.7-.1 2.3-.9 2.6-1.8.3-.9.3-1.6.2-1.8-.1-.2-.4-.3-.8-.5Z"
