---
const year = new Date().getFullYear();
---

<footer class="mt-12 overflow-hidden rounded-t-[2.5rem] bg-brand-navy text-white shadow-soft">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <div class="text-sm font-extrabold tracking-tight text-white">Aire Residencial</div>
        <p class="mt-2 text-sm text-white/75">
          Mantenimiento, reparación e instalación de aire acondicionado para hogares.
        </p>
      </div>

      <div>
        <div class="text-sm font-bold text-white">Contacto</div>
        <div class="mt-3 grid gap-2 text-sm text-white/75">
          <a class="hover:underline" href="tel:+529931524978">Tel: +52 99 31 52 49 78</a>
          <a class="hover:underline" href="mailto:contacto@tudominio.com">contacto@tudominio.com</a>
        </div>
      </div>

      <div>
        <div class="text-sm font-bold text-white">Área de cobertura</div>
        <p class="mt-3 text-sm text-white/75">
          Villahermosa, Tabasco y alrededores.
        </p>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-white/15 pt-6 text-xs text-white/70 sm:flex-row sm:items-center sm:justify-between">
      <div>© {year} Aire Residencial. Todos los derechos reservados.</div>
      <div>Servicio estrictamente residencial.</div>
    </div>

    <div class="mt-4 text-center text-xs text-white/70">
      Desarrollado por <span class="text-brand-gold">Agencia AX</span>
    </div>
  </div>
</footer>
