---
---

<form class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft" method="post" action="#">
  <div class="rounded-2xl bg-slate-50 px-4 py-3">
    <div class="text-sm font-extrabold tracking-tight text-brand-navy">Obtén tu presupuesto gratis hoy</div>
    <div class="mt-1 text-xs text-slate-600">Respuesta rápida y 100% residencial.</div>
  </div>

  <div class="mt-4 grid gap-3">
    <div>
      <label class="sr-only" for="lead-nombre">Nombre</label>
      <input
        id="lead-nombre"
        name="nombre"
        required
        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-brand-gold/40 focus:ring-4"
        placeholder="Nombre"
      />
    </div>

    <div>
      <label class="sr-only" for="lead-email">Email</label>
      <input
        id="lead-email"
        name="email"
        type="email"
        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-brand-gold/40 focus:ring-4"
        placeholder="Email"
      />
    </div>

    <div>
      <label class="sr-only" for="lead-telefono">Teléfono</label>
      <input
        id="lead-telefono"
        name="telefono"
        required
        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-brand-gold/40 focus:ring-4"
        placeholder="Teléfono"
      />
    </div>

    <button
      type="submit"
      class="mt-1 inline-flex w-full items-center justify-center rounded-2xl bg-brand-gold px-5 py-3 text-sm font-extrabold tracking-wide text-slate-950 shadow-soft ring-1 ring-black/5 hover:brightness-95"
    >
      PEDIR PRESUPUESTO
    </button>

    <p class="text-[11px] leading-relaxed text-slate-500">
      Formulario de demostración (sin backend). Si quieres, lo conecto a WhatsApp o a un servicio de formularios.
    </p>
  </div>
</form>
