---
const nav = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#beneficios', label: 'Beneficios' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="site-header fixed inset-x-0 top-0 z-50 border-b transition-colors" data-site-header>
  <div class="mx-auto grid max-w-6xl grid-cols-2 items-center gap-3 px-4 py-3 sm:px-6 md:grid-cols-[auto,1fr,auto]">
    <a href="#inicio" class="group inline-flex items-center gap-2">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-brand-navy text-white shadow-sm">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2C9.3 4.1 7.7 6.9 7.7 10c0 3.9 2.7 6.4 4.3 7.7 1.6-1.3 4.3-3.8 4.3-7.7C16.3 6.9 14.7 4.1 12 2Z" stroke="currentColor" stroke-width="1.6"/>
          <path d="M12 22c-3.8-1.7-6.3-4.6-6.3-8.2 0-1 .2-2 .6-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M12 22c3.8-1.7 6.3-4.6 6.3-8.2 0-1-.2-2-.6-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="leading-tight">
        <div class="header-title text-sm font-semibold tracking-tight">Aire Residencial</div>
      </div>
    </a>

    <nav class="hidden items-center justify-center justify-self-center gap-7 md:flex" aria-label="Navegación principal">
      {nav.map((item) => (
        <a href={item.href} class="header-link text-sm font-medium transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href="#contacto"
        class="inline-flex items-center justify-center rounded-xl bg-brand-gold px-5 py-2.5 text-sm font-extrabold tracking-wide text-slate-950 shadow-soft ring-1 ring-black/5 hover:brightness-95"
      >
        Cotizar ahora
      </a>
    </div>

    <details class="relative justify-self-end md:hidden">
      <summary class="header-menu-btn list-none rounded-xl border px-3 py-2 text-sm font-semibold shadow-sm">
        Menú
      </summary>

      <div class="absolute right-0 mt-3 w-[min(92vw,20rem)] rounded-2xl border border-slate-200 bg-white p-3 shadow-soft">
        <nav class="grid gap-1" aria-label="Navegación móvil">
          {nav.map((item) => (
            <a href={item.href} class="rounded-xl px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-brand-navy">
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-3">
          <a
            href="#contacto"
            class="inline-flex w-full items-center justify-center rounded-xl bg-brand-gold px-4 py-2 text-sm font-semibold text-slate-950 shadow-soft ring-1 ring-black/5 hover:brightness-95"
          >
            Cotizar ahora
          </a>
        </div>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    if (!header) return;

    const threshold = 8;
    let ticking = false;

    const update = () => {
      const scrolled = window.scrollY > threshold;
      header.classList.toggle('is-scrolled', scrolled);
      ticking = false;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<style>
  .site-header {
    background: transparent;
    border-bottom-color: transparent;
  }

  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.9);
    border-bottom-color: rgb(226 232 240);
    backdrop-filter: blur(12px);
  }

  .site-header .header-title,
  .site-header .header-link,
  .site-header .header-menu-btn {
    color: rgba(255, 255, 255, 0.95);
  }

  .site-header.is-scrolled .header-title {
    color: rgb(0 61 100);
  }

  .site-header.is-scrolled .header-link,
  .site-header.is-scrolled .header-menu-btn {
    color: rgb(0 61 100);
  }

  .site-header.is-scrolled .header-link:hover {
    color: rgb(0 61 100);
  }

  .site-header .header-menu-btn {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .site-header.is-scrolled .header-menu-btn {
    background: white;
    border-color: rgb(226 232 240);
  }
</style>
